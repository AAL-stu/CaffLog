/* app.wxss - CaffLog 全局样式 */

/* 颜色变量 */
page {
  --color-primary: #6B4E3D;
  --color-bg: #F5F0EB;
  --color-bg-light: #E8E0D5;
  --color-card: #FFFFFF;
  --color-text: #2C2416;
  --color-text-secondary: #8B8178;
  --color-warning: #F0AD4E;
  --color-danger: #E74C3C;
  --color-safe: #5CB85C;

  background: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
  box-sizing: border-box;
}

/* 重置按钮样式 */
button {
  background: initial;
}
button:focus {
  outline: 0;
}
button::after {
  border: none;
}

/* 通用容器 */
.page-container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--color-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 标题样式 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

/* 描述性副文本 */
.text-secondary {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.text-small {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #EEE;
  margin: 16rpx 0;
}

/* 弹性布局工具 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 间距工具 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }

/* 文本对齐 */
.text-center { text-align: center; }
.text-right { text-align: right; }
