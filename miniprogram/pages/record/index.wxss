/* pages/record/index.wxss */

/* Tab 切换 */
.tab-bar {
  display: flex;
  flex-direction: row;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-active {
  background: #6B4E3D;
}

.tab-active .tab-text {
  color: #FFFFFF;
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 26rpx;
  color: #8B8178;
  font-weight: 500;
}

/* 表单 */
.form-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #2C2416;
  margin-bottom: 12rpx;
}

.form-hint {
  font-size: 22rpx;
  color: #8B8178;
  margin-top: 8rpx;
}

.picker-input {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #F5F0EB;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2C2416;
}

.picker-arrow {
  color: #8B8178;
  font-size: 24rpx;
}

.weight-input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #F5F0EB;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.input-focused {
  border-color: #6B4E3D;
  background: #FFFFFF;
}

.weight-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C2416;
}

.weight-unit {
  font-size: 26rpx;
  color: #8B8178;
  margin-left: 8rpx;
}

/* 品牌选择（横向滚动） */
.brand-scroll {
  width: 100%;
  white-space: nowrap;
}

.brand-tabs {
  display: inline-flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 4rpx 0;
}

.brand-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  padding: 18rpx 24rpx;
  background: #F5F0EB;
  border-radius: 12rpx;
  transition: all 0.2s;
  white-space: nowrap;
}

.brand-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #8B8178;
  line-height: 1.3;
}

.brand-en {
  font-size: 20rpx;
  color: #BBB;
  line-height: 1.3;
  margin-top: 2rpx;
}

.brand-active {
  background: #6B4E3D;
}

.brand-active .brand-name {
  color: #FFFFFF;
}

.brand-active .brand-en {
  color: rgba(255,255,255,0.7);
}

/* 结果卡片 */
.result-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.result-main {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 12rpx;
}

.result-prefix {
  font-size: 28rpx;
  color: #8B8178;
  margin-right: 4rpx;
}

.result-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #2C2416;
  line-height: 1;
}

.result-unit {
  font-size: 28rpx;
  color: #8B8178;
  margin-left: 6rpx;
}

.result-range {
  font-size: 24rpx;
  color: #8B8178;
}

/* 提交按钮 */
.submit-area {
  margin-bottom: 16rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #6B4E3D;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  padding: 0;
  line-height: 1;
}

.btn-disabled {
  background: #CCC;
  color: #999;
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  font-size: 20rpx;
  color: #BBB;
  padding: 16rpx 0;
}
