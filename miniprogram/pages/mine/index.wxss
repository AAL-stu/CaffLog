/* pages/mine/index.wxss */

/* 用户信息卡 */
.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
  margin-bottom: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 16rpx;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E8E0D5;
}

.avatar-text {
  font-size: 48rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C2416;
}

.login-hint {
  font-size: 22rpx;
  color: #8B8178;
  margin-top: 8rpx;
}

/* 统计数据 */
.stats-card {
  display: flex;
  flex-direction: row;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #6B4E3D;
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: #8B8178;
  margin-top: 8rpx;
}

/* 菜单列表 */
.menu-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F0EB;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #2C2416;
}

.menu-arrow {
  font-size: 28rpx;
  color: #CCC;
}

/* 版本信息 */
.version-info {
  text-align: center;
  font-size: 22rpx;
  color: #BBB;
  padding: 24rpx;
}
