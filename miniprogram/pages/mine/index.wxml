<!--pages/mine/index.wxml-->
<view class="page-container">

  <!-- 用户信息卡 -->
  <view class="user-card" bindtap="onLogin">
    <image
      wx:if="{{avatarUrl}}"
      class="avatar"
      src="{{avatarUrl}}"
      mode="aspectFill"
    />
    <view wx:else class="avatar avatar-placeholder">
      <text class="avatar-text">☕</text>
    </view>
    <text class="nickname">{{nickName}}</text>
    <text wx:if="{{!isLogin}}" class="login-hint">点击登录，同步数据到云端</text>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{totalRecords}}</text>
      <text class="stat-label">累计记录</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goSettings">
      <text class="menu-icon">⚙</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ</text>
      <text class="menu-text">关于 CaffLog</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本 -->
  <view class="version-info">
    <text>CaffLog v1.0</text>
  </view>
</view>
