/* components/ring-progress/index.wxss */
.ring-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-canvas {
  position: absolute;
  top: 0;
  left: 0;
}

.ring-center {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.current-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #2C2416;
  line-height: 1;
}

.current-unit {
  font-size: 22rpx;
  color: #8B8178;
  margin-top: 2rpx;
}

.max-label {
  font-size: 24rpx;
  color: #8B8178;
  margin-top: 4rpx;
}

.remaining {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.text-safe {
  color: #5CB85C;
}

.text-danger {
  color: #E74C3C;
  font-weight: 600;
}
